# Windows download artifacts
*:Zone.Identifier

# OS files
.DS_Store
Thumbs.db

# Editor/IDE
.vscode/
.idea/
*.swp
*~

# Python
__pycache__/
*.pyc

# Python build artifacts (wheel/sdist)
/dist/
/build/
*.egg-info/
# CI/local wheel-install smoke-test venv
/.wheeltest/

# Environment / secrets
.env
.env.*
# Credential / key files (should never be committed)
*.pem
*.key
*.p12
*.pfx
*.jks
*.keystore
.netrc
.npmrc
.pypirc
service-account*.json
credentials*.json

# Local scratch / working files
tmp/

# agent-workflows installer local backups
.agent-workflows-installer-backups/

# Session-recovery transcripts / dumps: machine-local, may contain personal paths
# and session ids; never track (D92).
opencode-recovery/

# Ephemeral workflow run records (release-review / assess run logs). They embed
# machine-absolute paths; kept local, not tracked (D92).
workflow-artifacts/
